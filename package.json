{
  "name": "@anthropic/iab-taxonomies",
  "version": "1.0.0",
  "description": "IAB Tech Lab Taxonomies (Content, Ad Product, Audience) with OpenRTB cattax support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build:data": "tsx scripts/build-json.ts",
    "build:ts": "tsc",
    "build": "npm run build:data && npm run build:ts",
    "test": "tsx scripts/verify.ts"
  },
  "files": [
    "dist",
    "data"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.1"
  }
}
